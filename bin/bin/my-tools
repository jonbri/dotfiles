#!/bin/bash
# my-tools - give a summary of my tools

DOTFILES=${HOME}/dotfiles
DOTFILES_BIN=${DOTFILES}/bin/bin/*

for filename in $DOTFILES_BIN; do
    if [[ `cat ${filename}` == *"bash"* ]]; then
        secondLine=`sed -n '2p' $filename`
        secondLine="${secondLine:2}"
        echo $secondLine
    fi
done

