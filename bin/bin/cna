#!/bin/bash
# cna - run create-nova-app locally

# usage: pass in name of app to be created

NC=/home/jonbri/nova-commons
APP_NAME=$1

mkdir -p /home/jonbri/apps
cd /home/jonbri/apps

npx cross-env CNA_DEV=true node $NC/tools/create-nova-app/createNovaApp.js $APP_NAME --scripts-version file:$NC/tools/nova-scripts --template file:$NC/tools/templates/base
